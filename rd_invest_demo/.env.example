# Core runtime
PORT=3210
DEFAULT_REPORT_MONTH=2025-11
DEFAULT_REPORT_YEAR=2025

# Optional custom paths (relative path is resolved from project root)
# DB_PATH=data/rd_demo.db
# UPLOAD_DIR=uploads
# TMP_DIR=tmp

# LLM defaults for frontend selector/runtime
DEFAULT_LLM_PROVIDER=deepseek
DEFAULT_DEEPSEEK_MODEL=deepseek-chat
DEFAULT_OPENAI_MODEL=gpt-4o-mini

# Secrets (fill your own, never commit real keys)
DS_API_KEY=
OPENAI_API_KEY=
